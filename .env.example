# Nexus Miner - Environment Variables
# Copie este arquivo para .env e ajuste os valores

# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./data/nexusminer.db

# JWT Secrets (MUDE EM PRODUCAO!)
JWT_SECRET=nexus_miner_jwt_secret_key_change_this_in_production_2024_64chars_minimum_length
JWT_REFRESH_SECRET=nexus_miner_refresh_secret_key_change_this_too_in_production_2024_64

# WhatsApp (Baileys)
WHATSAPP_ENABLED=false
WHATSAPP_SESSION_PATH=./data/whatsapp

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION_MS=1800000

# Backup
BACKUP_INTERVAL_MS=86400000
BACKUP_KEEP=10

# OneSignal Push Notifications (grátis até 10.000 assinantes)
# Crie em: https://onesignal.com
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
